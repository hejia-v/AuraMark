                      Figures="M4.25 8.333V3.868a.66.66 0 0 1 1.038-.54l3.19 2.232a.66.66 0 0 1 0 1.081l-3.19 2.233a.66.66 0 0 1-1.038-.541" />
        <PathGeometry x:Key="ChevronDownGeometry"
                      Figures="M3.668 4.25h4.465a.66.66 0 0 1 .54 1.038l-2.232 3.19a.66.66 0 0 1-1.081 0l-2.233-3.19a.66.66 0 0 1 .541-1.038" />
        <PathGeometry x:Key="FolderIconGeometry"
