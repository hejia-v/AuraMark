        <!-- Tree context menu: Nord palette, rounded, subtle shadow -->
        <Style x:Key="TreeContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Padding" Value="0,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="#FFFFFF"
                                BorderBrush="#DDE3EC"
                                BorderThickness="1"
                                CornerRadius="8"
                                MinWidth="200"
                                Padding="0,4">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="2"
                                                  Direction="270" Opacity="0.12" Color="#000000" />
                            </Border.Effect>
                            <ItemsPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TreeMenuItemStyle" TargetType="MenuItem">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="12,0,16,0" />
            <Setter Property="Foreground" Value="#434C5E" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bg" Background="Transparent"
                                Margin="4,1" CornerRadius="5">
                            <ContentPresenter ContentSource="Header"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#EEF1F5" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#B0BAC6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TreeMenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="8,3" />
            <Setter Property="Background" Value="#E8ECF2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Background="{TemplateBinding Background}"
                                Margin="{TemplateBinding Margin}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- File tree HierarchicalDataTemplate: shows folder/file icon + name -->
        <HierarchicalDataTemplate DataType="{x:Type models:FileTreeNode}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2,1,6,1">
                <Path x:Name="ItemIcon"
                      Width="14" Height="14"
                      Margin="0,0,5,0"
                      VerticalAlignment="Center"
                      Stretch="Uniform"
                      Fill="#8A9BB0"
                      Data="{StaticResource FileIconGeometry}" />
                <TextBlock x:Name="ItemName"
                           Text="{Binding Name}"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Foreground="#434C5E" />
                <!-- Rename TextBox（默认隐藏，IsRenaming=True 时显示） -->
                <TextBox x:Name="RenameBox"
                         Text="{Binding Name, Mode=OneTime}"
                         FontSize="13"
                         VerticalAlignment="Center"
                         BorderThickness="1"
                         BorderBrush="#81A1C1"
                         Background="#FFFFFF"
                         Padding="2,0"
                         MinWidth="80"
                         Visibility="Collapsed"
                         KeyDown="OnRenameBoxKeyDown"
                         LostFocus="OnRenameBoxLostFocus" />
            </StackPanel>
            <HierarchicalDataTemplate.Triggers>
                <!-- Directory (collapsed): closed folder icon -->
                <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                    <Setter TargetName="ItemIcon" Property="Data" Value="{StaticResource FolderClosedIconGeometry}" />
                    <Setter TargetName="ItemIcon" Property="Fill" Value="#6B8BAD" />
                    <Setter TargetName="ItemName" Property="FontWeight" Value="SemiBold" />
                    <Setter TargetName="ItemName" Property="Foreground" Value="#3D4A5C" />
                </DataTrigger>
                <!-- Directory (expanded): open folder icon -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsDirectory}" Value="True" />
                        <Condition Binding="{Binding IsExpanded}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ItemIcon" Property="Data" Value="{StaticResource FolderOpenIconGeometry}" />
                </MultiDataTrigger>
                <!-- Skill folder: overrides folder icon with 3-D box regardless of expand state -->
                <DataTrigger Binding="{Binding IsSkill}" Value="True">
                    <Setter TargetName="ItemIcon" Property="Data" Value="{StaticResource SkillFolderIconGeometry}" />
                </DataTrigger>
                <!-- Markdown files (.md / .markdown) -->
                <DataTrigger Binding="{Binding Extension}" Value=".md">
                    <Setter TargetName="ItemIcon" Property="Data" Value="{StaticResource MarkdownFileIconGeometry}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Extension}" Value=".markdown">
                    <Setter TargetName="ItemIcon" Property="Data" Value="{StaticResource MarkdownFileIconGeometry}" />
                </DataTrigger>
                <!-- Plain text files (.txt) -->
                <DataTrigger Binding="{Binding Extension}" Value=".txt">
                    <Setter TargetName="ItemIcon" Property="Data" Value="{StaticResource TextFileIconGeometry}" />
                </DataTrigger>
                <!-- SKILL.md: light purple accent (overrides generic .md trigger) -->
                <DataTrigger Binding="{Binding Name}" Value="SKILL.md">
                    <Setter TargetName="ItemIcon" Property="Fill" Value="#7C5CBF" />
                    <Setter TargetName="ItemName" Property="Foreground" Value="#6B4DAE" />
                </DataTrigger>
                <!-- Rename mode: hide label, show TextBox -->
                <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                    <Setter TargetName="ItemName" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="RenameBox" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>

        <!-- File tree item style: chevron expander, icons, hover/selection feedback -->
        <Style x:Key="FileTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <!-- Row header -->
                            <Border x:Name="RowBg"
                                    CornerRadius="5"
                                    Background="Transparent"
                                    Margin="2,1"
                                    Padding="4,0"
                                    PreviewMouseLeftButtonDown="OnTreeItemMouseLeftDown"
                                    PreviewMouseMove="OnTreeItemPreviewMouseMove">
                                <Border.ContextMenu>
                                    <ContextMenu Style="{StaticResource TreeContextMenuStyle}">
                                        <MenuItem Header="复制名称"     Style="{StaticResource TreeMenuItemStyle}"
                                                  Click="OnTreeMenuCopyName" />
                                        <MenuItem Header="复制路径"     Style="{StaticResource TreeMenuItemStyle}"
                                                  Click="OnTreeMenuCopyPath" />
                                        <MenuItem Header="复制相对路径" Style="{StaticResource TreeMenuItemStyle}"
                                                  Click="OnTreeMenuCopyRelativePath" />
                                        <Separator Style="{StaticResource TreeMenuSeparatorStyle}" />
                                        <MenuItem x:Name="TreeMenuOpenInExplorerMenuItem"
                                                  Header="在文件管理器打开"
                                                  Style="{StaticResource TreeMenuItemStyle}"
                                                  Click="OnTreeMenuOpenInExplorer" />
                                        <Separator Style="{StaticResource TreeMenuSeparatorStyle}" />
                                        <MenuItem Header="重命名"       Style="{StaticResource TreeMenuItemStyle}"
                                                  Click="OnTreeMenuRename" />
                                        <Separator Style="{StaticResource TreeMenuSeparatorStyle}" />
                                        <MenuItem Header="新建 Markdown 文件" Style="{StaticResource TreeMenuItemStyle}"
                                                  Click="OnTreeMenuNewMarkdown" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Expand/collapse toggle button with chevron icon -->
                                    <ToggleButton x:Name="Expander"
                                                  Grid.Column="0"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Visibility="Hidden"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" Width="16" Height="22">
                                                    <Path x:Name="ChevronIcon"
                                                          Width="8" Height="8"
                                                          Stretch="Uniform"
                                                          Fill="#9AA4B0"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"
                                                          Data="{StaticResource ChevronRightGeometry}" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="ChevronIcon" Property="Data" Value="{StaticResource ChevronDownGeometry}" />
                                                        <Setter TargetName="ChevronIcon" Property="Fill" Value="#6B8BAD" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ChevronIcon" Property="Fill" Value="#3D4A5C" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>

                                    <!-- Item header content (HierarchicalDataTemplate) -->
                                    <ContentPresenter x:Name="PART_Header"
                                                      Grid.Column="1"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <!-- Child items, indented -->
                            <ItemsPresenter x:Name="ItemsHost"
                                            Margin="12,0,0,0"
                                            Visibility="Collapsed" />
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <!-- Show chevron only for folders with children -->
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="Expander" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <!-- Expand children on toggle -->
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <!-- Hover state -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBg" Property="Background" Value="#D0E3F5" />
                            </Trigger>
                            <!-- Selected + focused -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsSelectionActive" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="RowBg" Property="Background" Value="#DDE6F0" />
                            </MultiTrigger>
                            <!-- Selected + unfocused -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsSelectionActive" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="RowBg" Property="Background" Value="#EEF1F5" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ================================================================
             Sidebar thin scrollbar
             Thumb: pill shape, 5 px wide, no arrows, transparent track
        ================================================================ -->
        <Style x:Key="SidebarScrollBarThumb" TargetType="Thumb">
