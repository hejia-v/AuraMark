        <PathGeometry x:Key="FileIconGeometry"
                      Figures="M15.169 6.5c0-.711-.001-1.204-.033-1.588a2.4 2.4 0 0 0-.112-.615l-.055-.13a1.84 1.84 0 0 0-.676-.731l-.126-.07c-.158-.081-.37-.138-.745-.169-.384-.031-.877-.032-1.588-.032H8.167c-.711 0-1.205 0-1.588.032-.376.031-.587.088-.745.168a1.84 1.84 0 0 0-.802.802c-.08.158-.137.37-.168.745-.031.384-.032.877-.032 1.588v7c0 .711 0 1.204.032 1.588.03.376.088.587.168.745l.07.127c.177.288.43.522.732.676l.13.056c.143.051.333.089.615.112.383.031.877.031 1.588.031h3.667c.71 0 1.204 0 1.588-.031.375-.031.587-.088.745-.168l.126-.07c.287-.177.522-.43.676-.732l.055-.13c.052-.144.09-.333.113-.615.03-.384.032-.877.032-1.588z M16.499 13.5c0 .69 0 1.246-.037 1.696-.033.4-.097.762-.241 1.098l-.068.142c-.265.522-.669.958-1.165 1.262l-.218.122c-.376.192-.782.271-1.24.309-.45.037-1.007.036-1.696.036H8.167c-.69 0-1.246 0-1.697-.036-.4-.033-.76-.098-1.097-.242l-.143-.067a3.17 3.17 0 0 1-1.261-1.165l-.123-.219c-.191-.376-.27-.782-.308-1.24-.037-.45-.036-1.007-.036-1.696v-7c0-.69 0-1.246.036-1.696.037-.458.117-.864.308-1.24A3.17 3.17 0 0 1 5.23 2.18c.377-.192.783-.271 1.24-.309.45-.037 1.008-.036 1.697-.036h3.667c.689 0 1.246 0 1.696.036.458.038.864.117 1.24.309l.218.122c.496.304.9.74 1.165 1.261l.068.143c.144.336.208.697.24 1.098.038.45.038 1.007.038 1.696z" />

        <!-- File tree HierarchicalDataTemplate: shows folder/file icon + name -->
        <HierarchicalDataTemplate DataType="{x:Type models:FileTreeNode}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2,1,6,1">
                <Path x:Name="ItemIcon"
                      Width="14" Height="14"
                      Margin="0,0,5,0"
                      VerticalAlignment="Center"
                      Stretch="Uniform"
                      Fill="#8A9BB0"
                      Data="{StaticResource FileIconGeometry}" />
                <TextBlock x:Name="ItemName"
                           Text="{Binding Name}"
                           FontSize="13"
                           VerticalAlignment="Center"
                           Foreground="#434C5E" />
            </StackPanel>
            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                    <Setter TargetName="ItemIcon" Property="Data" Value="{StaticResource FolderIconGeometry}" />
                    <Setter TargetName="ItemIcon" Property="Fill" Value="#6B8BAD" />
                    <Setter TargetName="ItemName" Property="FontWeight" Value="SemiBold" />
                    <Setter TargetName="ItemName" Property="Foreground" Value="#3D4A5C" />
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>

        <!-- File tree item style: chevron expander, icons, hover/selection feedback -->
        <Style x:Key="FileTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <StackPanel>
                            <!-- Row header -->
                            <Border x:Name="RowBg"
                                    CornerRadius="5"
                                    Background="Transparent"
                                    Margin="2,1"
                                    Padding="4,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Expand/collapse toggle button with chevron icon -->
                                    <ToggleButton x:Name="Expander"
                                                  Grid.Column="0"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Visibility="Hidden"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent" Width="16" Height="22">
                                                    <Path x:Name="ChevronIcon"
                                                          Width="8" Height="8"
                                                          Stretch="Uniform"
                                                          Fill="#9AA4B0"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"
                                                          Data="{StaticResource ChevronRightGeometry}" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="ChevronIcon" Property="Data" Value="{StaticResource ChevronDownGeometry}" />
                                                        <Setter TargetName="ChevronIcon" Property="Fill" Value="#6B8BAD" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ChevronIcon" Property="Fill" Value="#3D4A5C" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>

                                    <!-- Item header content (HierarchicalDataTemplate) -->
                                    <ContentPresenter x:Name="PART_Header"
                                                      Grid.Column="1"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <!-- Child items, indented -->
                            <ItemsPresenter x:Name="ItemsHost"
                                            Margin="12,0,0,0"
                                            Visibility="Collapsed" />
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <!-- Show chevron only for folders with children -->
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="Expander" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <!-- Expand children on toggle -->
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <!-- Hover state -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBg" Property="Background" Value="#EEF1F5" />
                            </Trigger>
                            <!-- Selected + focused -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsSelectionActive" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="RowBg" Property="Background" Value="#DDE6F0" />
                            </MultiTrigger>
                            <!-- Selected + unfocused -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsSelectionActive" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="RowBg" Property="Background" Value="#EEF1F5" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- File tree view: no border, horizontal scroll disabled, items use FileTreeItemStyle -->
        <Style x:Key="FileTreeViewStyle" TargetType="TreeView">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource FileTreeItemStyle}" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeView">
                        <ScrollViewer Focusable="False"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 圆形图标按钮 Style -->
        <Style x:Key="CircularIconButton" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#B8C8D8" />
            <Setter Property="Background" Value="#E8EEF4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#C8DCEA" />
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#81A1C1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#AECBE0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 无背景浮动图标按钮 Style（用于展开面板的 Popup 按钮） -->
        <Style x:Key="GhostIconButton" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#28434C5E" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#45434C5E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 面板标题栏图标按钮 Style（圆角矩形，22×22） -->
        <Style x:Key="PanelIconButton" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#20434C5E" />
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#35434C5E" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#38434C5E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 窗口最小化按钮 Style -->
        <Style x:Key="WindowMinimizeButton" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="22" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <TextBlock x:Name="Icon"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="—"
                                       FontSize="12"
                                       Foreground="#8090A4" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#E2E8F0" />
                                <Setter TargetName="Icon" Property="Foreground" Value="#3D4A5C" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#CBD5E1" />
                                <Setter TargetName="Icon" Property="Foreground" Value="#3D4A5C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 窗口关闭按钮 Style -->
        <Style x:Key="WindowCloseButton" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="22" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <TextBlock x:Name="Icon"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="✕"
                                       FontSize="11"
                                       Foreground="#8090A4" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#E05252" />
                                <Setter TargetName="Icon" Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#C03838" />
                                <Setter TargetName="Icon" Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 顶栏 Menu 容器样式 -->
        <Style x:Key="TopBarMenuStyle" TargetType="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- 菜单项通用样式（Role 触发器区分顶层/子项） -->
        <Style x:Key="MenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#434C5E" />
            <Setter Property="FontSize" Value="13" />
            <Style.Triggers>

                <!-- 顶层菜单按钮（File / View） -->
                <Trigger Property="Role" Value="TopLevelHeader">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="MenuItem">
                                <Grid>
                                    <Border x:Name="Bg"
                                            CornerRadius="6"
                                            Padding="10,4"
                                            Background="Transparent">
                                        <ContentPresenter ContentSource="Header"
                                                          RecognizesAccessKey="True"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                    <Popup x:Name="PART_Popup"
                                           IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                           Placement="Bottom"
                                           VerticalOffset="4"
                                           AllowsTransparency="True"
                                           Focusable="False"
                                           PopupAnimation="Fade">
                                        <Border Margin="4,0,6,8"
                                                Background="#FFFFFF"
                                                BorderBrush="#DDE3EC"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                MinWidth="188"
                                                Padding="4">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#000000"
                                                                  Opacity="0.10"
                                                                  BlurRadius="18"
                                                                  ShadowDepth="4"
                                                                  Direction="270" />
                                            </Border.Effect>
                                            <ItemsPresenter />
                                        </Border>
                                    </Popup>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#EEF1F5" />
                                    </Trigger>
                                    <Trigger Property="IsSubmenuOpen" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#E4EAF2" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>

                <!-- 下拉菜单项 -->
                <Trigger Property="Role" Value="SubmenuItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="MenuItem">
                                <Border x:Name="Bg"
                                        Background="Transparent"
                                        CornerRadius="5"
                                        Padding="10,6"
                                        Margin="0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter ContentSource="Header"
                                                          RecognizesAccessKey="True"
                                                          VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Margin="24,0,2,0"
                                                   Text="{TemplateBinding InputGestureText}"
                                                   Foreground="#9AA4B0"
                                                   FontSize="11"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#EEF1F5" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Foreground" Value="#B0BAC6" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>

                <!-- 带子菜单的下拉项（如 Recent） -->
                <Trigger Property="Role" Value="SubmenuHeader">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="MenuItem">
                                <Grid>
                                    <Border x:Name="Bg"
                                            Background="Transparent"
                                            CornerRadius="5"
                                            Padding="10,6"
                                            Margin="0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter ContentSource="Header"
                                                              RecognizesAccessKey="True"
                                                              VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="›"
                                                       Margin="16,0,2,0"
                                                       Foreground="#9AA4B0"
                                                       FontSize="16"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                    <Popup x:Name="PART_Popup"
                                           IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                           Placement="Right"
                                           HorizontalOffset="-4"
                                           VerticalOffset="-8"
                                           AllowsTransparency="True"
                                           Focusable="False"
                                           PopupAnimation="Fade">
                                        <Border Margin="0,0,6,8"
                                                Background="#FFFFFF"
                                                BorderBrush="#DDE3EC"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                MinWidth="280"
                                                Padding="4">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#000000"
                                                                  Opacity="0.10"
                                                                  BlurRadius="18"
                                                                  ShadowDepth="4"
                                                                  Direction="270" />
                                            </Border.Effect>
                                            <ItemsPresenter />
                                        </Border>
                                    </Popup>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#EEF1F5" />
                                    </Trigger>
                                    <Trigger Property="IsSubmenuOpen" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#E4EAF2" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Foreground" Value="#B0BAC6" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>

            </Style.Triggers>
        </Style>

        <!-- 下拉菜单分隔线样式 -->
        <Style x:Key="MenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="8,3" />
            <Setter Property="Background" Value="#E8ECF2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1"
                                Background="{TemplateBinding Background}"
                                Margin="{TemplateBinding Margin}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border BorderBrush="#38000000"
            BorderThickness="1"
            CornerRadius="12"
            ClipToBounds="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="TopBar"
                Grid.Row="0"
                Background="#F3F4F6"
                BorderBrush="#1A434C5E"
                BorderThickness="0,0,0,1"
                Opacity="1"
                MouseLeftButtonDown="OnTopBarMouseLeftButtonDown">
            <Grid Margin="14,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Menu Style="{StaticResource TopBarMenuStyle}"
                      shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <MenuItem Header="File" Style="{StaticResource MenuItemStyle}">
                        <MenuItem Header="New"
                                  Style="{StaticResource MenuItemStyle}"
                                  InputGestureText="Ctrl+N"
                                  Click="OnNewFileClicked" />
                        <MenuItem Header="Open File…"
                                  Style="{StaticResource MenuItemStyle}"
                                  InputGestureText="Ctrl+O"
                                  Click="OnOpenFileClicked" />
                        <MenuItem Header="Open Folder…"
                                  Style="{StaticResource MenuItemStyle}"
                                  Click="OnOpenFolderClicked" />
                        <Separator Style="{StaticResource MenuSeparatorStyle}" />
                        <MenuItem x:Name="RecentMenuItem"
                                  Header="Recent"
                                  Style="{StaticResource MenuItemStyle}" />
                        <Separator Style="{StaticResource MenuSeparatorStyle}" />
                        <MenuItem Header="Save"
                                  Style="{StaticResource MenuItemStyle}"
                                  InputGestureText="Ctrl+S"
                                  Click="OnSaveNowClicked" />
                        <Separator Style="{StaticResource MenuSeparatorStyle}" />
                        <MenuItem Header="Export…"
                                  Style="{StaticResource MenuItemStyle}"
                                  Click="OnExportHtmlClicked" />
                    </MenuItem>
                    <MenuItem Header="View" Style="{StaticResource MenuItemStyle}">
                        <MenuItem Header="Toggle Workspace"
                                  Style="{StaticResource MenuItemStyle}"
                                  InputGestureText="Ctrl+Shift+L"
                                  Click="OnToggleSidebarClicked" />
                        <MenuItem Header="Toggle Outline"
                                  Style="{StaticResource MenuItemStyle}"
                                  InputGestureText="Ctrl+Shift+O"
                                  Click="OnToggleOutlineClicked" />
                    </MenuItem>
                </Menu>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock x:Name="FileNameText"
                               Margin="0,0,12,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#434C5E"
                               Text="Untitled.md" />
                    <TextBlock x:Name="StateText"
                               FontSize="12"
                               Foreground="#8C434C5E"
                               Text="Idle" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <Button x:Name="MinimizeButton"
                            Style="{StaticResource WindowMinimizeButton}"
                            Margin="0,0,2,0"
                            Click="OnMinimizeClicked"
                            ToolTip="Minimize"
                            AutomationProperties.AutomationId="WindowMinimizeButton"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                    <Button x:Name="CloseButton"
                            Style="{StaticResource WindowCloseButton}"
                            Click="OnCloseClicked"
                            ToolTip="Close"
                            AutomationProperties.AutomationId="WindowCloseButton"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border x:Name="SidebarContainer"
                    Width="0"
                    Background="#F3F4F6"
                    BorderBrush="#1A434C5E"
                    BorderThickness="0,0,1,0"
                    Opacity="0"
                    Visibility="Collapsed">
                <Grid Margin="10,10,8,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#7C8A9C"
                                       Text="WORKSPACE" />
                            <TextBlock x:Name="WorkspaceFolderNameText"
                                       FontSize="12"
                                       Foreground="#5E7090"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,1,0,0"
                                       Visibility="Collapsed" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Style="{StaticResource PanelIconButton}"
                                VerticalAlignment="Top"
                                Margin="0,0,0,0"
                                Click="OnToggleSidebarClicked"
                                ToolTip="Toggle Workspace (Ctrl+Shift+L)">
                            <!-- 面板布局图标（836f7a.svg，20×20 坐标系） -->
                            <Path Width="14" Height="14"
                                  Stretch="Uniform"
                                  Fill="#5E6E82"
                                  Data="M6.835 4c-.451.004-.82.012-1.137.038-.386.032-.659.085-.876.162l-.2.086c-.44.224-.807.564-1.063.982l-.103.184c-.126.247-.206.562-.248 1.076-.043.523-.043 1.19-.043 2.135v2.664c0 .944 0 1.612.043 2.135.042.515.122.829.248 1.076l.103.184c.256.418.624.758 1.063.982l.2.086c.217.077.49.13.876.162.316.026.685.034 1.136.038zm11.33 7.327c0 .922 0 1.654-.048 2.243-.043.522-.125.977-.305 1.395l-.082.177a4 4 0 0 1-1.473 1.593l-.276.155c-.465.237-.974.338-1.57.387-.59.048-1.322.048-2.244.048H7.833c-.922 0-1.654 0-2.243-.048-.522-.042-.977-.126-1.395-.305l-.176-.082a4 4 0 0 1-1.594-1.473l-.154-.275c-.238-.466-.34-.975-.388-1.572-.048-.589-.048-1.32-.048-2.243V8.663c0-.922 0-1.654.048-2.243.049-.597.15-1.106.388-1.571l.154-.276a4 4 0 0 1 1.594-1.472l.176-.083c.418-.18.873-.263 1.395-.305.589-.048 1.32-.048 2.243-.048h4.334c.922 0 1.654 0 2.243.048.597.049 1.106.15 1.571.388l.276.154a4 4 0 0 1 1.473 1.594l.082.176c.18.418.262.873.305 1.395.048.589.048 1.32.048 2.243zm-10 4.668h4.002c.944 0 1.612 0 2.135-.043.514-.042.829-.122 1.076-.248l.184-.103c.418-.256.758-.624.982-1.063l.086-.2c.077-.217.13-.49.162-.876.043-.523.043-1.19.043-2.135V8.663c0-.944 0-1.612-.043-2.135-.032-.386-.085-.659-.162-.876l-.086-.2a2.67 2.67 0 0 0-.982-1.063l-.184-.103c-.247-.126-.562-.206-1.076-.248-.523-.043-1.19-.043-2.135-.043H8.164L8.165 4z" />
                        </Button>
                    </Grid>

                    <TreeView x:Name="FileTreeView"
                              Grid.Row="1"
                              Margin="0,6,0,0"
                              Style="{StaticResource FileTreeViewStyle}"
                              ItemsSource="{Binding FileTreeNodes}"
                              SelectedItemChanged="OnFileTreeSelectionChanged" />
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <wv2:WebView2 x:Name="MainWebView" Margin="14,10,14,14" />

                <Border x:Name="LoadingOverlay"
                        Margin="30,26,30,30"
                        Padding="18"
                        Background="#F2F9FAFB"
                        BorderBrush="#33434C5E"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="LoadingText"
                                   HorizontalAlignment="Center"
                                   FontSize="13"
                                   Foreground="#8C434C5E"
                                   Text="Loading document..." />
                        <ProgressBar Margin="0,12,0,0"
                                     Height="5"
                                     IsIndeterminate="True"
                                     Foreground="#81A1C1" />
                    </StackPanel>
                </Border>

                <Border x:Name="ErrorToast"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,16,22,0"
                        Padding="10,8"
                        Background="#33BF616A"
                        BorderBrush="#66BF616A"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="Collapsed"
                        Opacity="0">
                    <DockPanel>
                        <TextBlock x:Name="ErrorText"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   Foreground="#8F2D37"
                                   FontSize="12"
                                   Text="Save failed." />
                        <Button x:Name="RetrySaveButton"
                                Width="54"
                                Height="22"
                                BorderThickness="0"
                                Background="#99FFFFFF"
                                Foreground="#8F2D37"
                                AutomationProperties.AutomationId="RetrySaveButton"
                                Click="OnRetrySaveClicked"
                                Content="Retry" />
                    </DockPanel>
                </Border>

                <Border x:Name="SyncConflictToast"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,62,22,0"
                        Padding="10,8"
                        Background="#335E81AC"
                        BorderBrush="#665E81AC"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="Collapsed"
                        Opacity="0">
                    <DockPanel>
                        <TextBlock x:Name="SyncConflictText"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   Foreground="#3A4A63"
                                   FontSize="12"
                                   Text="External file changed. Keep local or reload external?" />
                        <Button x:Name="KeepLocalButton"
                                Width="72"
                                Height="22"
                                Margin="0,0,6,0"
                                BorderThickness="0"
                                Background="#99FFFFFF"
                                Foreground="#3A4A63"
                                AutomationProperties.AutomationId="KeepLocalButton"
                                Click="OnKeepLocalClicked"
                                Content="Keep Local" />
                        <Button x:Name="AcceptExternalButton"
                                Width="92"
                                Height="22"
                                BorderThickness="0"
                                Background="#99FFFFFF"
                                Foreground="#3A4A63"
                                AutomationProperties.AutomationId="AcceptExternalButton"
                                Click="OnAcceptExternalClicked"
                                Content="Use External" />
                    </DockPanel>
                </Border>

                <Border x:Name="SavingDot"
                        Width="9"
                        Height="9"
                        CornerRadius="4.5"
                        Background="#81A1C1"
                        Opacity="0.4"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,20,20"
                        Visibility="Collapsed" />
            </Grid>

            <Border x:Name="OutlineContainer"
                    Grid.Column="2"
                    Width="0"
                    Background="#F3F4F6"
                    BorderBrush="#1A434C5E"
                    BorderThickness="1,0,0,0"
                    Opacity="0"
                    Visibility="Collapsed">
                <Grid Margin="8,10,10,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Margin="0,0,6,0"
                                Style="{StaticResource PanelIconButton}"
                                Click="OnToggleOutlineClicked"
                                ToolTip="Toggle Outline (Ctrl+Shift+O)">
                            <!-- 同 836f7a.svg，水平镜像得到右侧面板图标 -->
                            <Path Width="14" Height="14"
                                  Stretch="Uniform"
                                  Fill="#5E6E82"
                                  Data="M6.835 4c-.451.004-.82.012-1.137.038-.386.032-.659.085-.876.162l-.2.086c-.44.224-.807.564-1.063.982l-.103.184c-.126.247-.206.562-.248 1.076-.043.523-.043 1.19-.043 2.135v2.664c0 .944 0 1.612.043 2.135.042.515.122.829.248 1.076l.103.184c.256.418.624.758 1.063.982l.2.086c.217.077.49.13.876.162.316.026.685.034 1.136.038zm11.33 7.327c0 .922 0 1.654-.048 2.243-.043.522-.125.977-.305 1.395l-.082.177a4 4 0 0 1-1.473 1.593l-.276.155c-.465.237-.974.338-1.57.387-.59.048-1.322.048-2.244.048H7.833c-.922 0-1.654 0-2.243-.048-.522-.042-.977-.126-1.395-.305l-.176-.082a4 4 0 0 1-1.594-1.473l-.154-.275c-.238-.466-.34-.975-.388-1.572-.048-.589-.048-1.32-.048-2.243V8.663c0-.922 0-1.654.048-2.243.049-.597.15-1.106.388-1.571l.154-.276a4 4 0 0 1 1.594-1.472l.176-.083c.418-.18.873-.263 1.395-.305.589-.048 1.32-.048 2.243-.048h4.334c.922 0 1.654 0 2.243.048.597.049 1.106.15 1.571.388l.276.154a4 4 0 0 1 1.473 1.594l.082.176c.18.418.262.873.305 1.395.048.589.048 1.32.048 2.243zm-10 4.668h4.002c.944 0 1.612 0 2.135-.043.514-.042.829-.122 1.076-.248l.184-.103c.418-.256.758-.624.982-1.063l.086-.2c.077-.217.13-.49.162-.876.043-.523.043-1.19.043-2.135V8.663c0-.944 0-1.612-.043-2.135-.032-.386-.085-.659-.162-.876l-.086-.2a2.67 2.67 0 0 0-.982-1.063l-.184-.103c-.247-.126-.562-.206-1.076-.248-.523-.043-1.19-.043-2.135-.043H8.164L8.165 4z">
                                <Path.LayoutTransform>
                                    <ScaleTransform ScaleX="-1" />
                                </Path.LayoutTransform>
                            </Path>
                        </Button>
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#8C434C5E"
                                   Text="OUTLINE" />
                    </Grid>

                    <ListBox x:Name="OutlineList"
                             Grid.Row="1"
                             Margin="0,6,0,0"
                             BorderThickness="0"
                             Background="#00000000"
                             Foreground="#434C5E"
                             DisplayMemberPath="DisplayText"
                             ItemsSource="{Binding OutlineItems}"
                             SelectionChanged="OnOutlineSelectionChanged" />
                </Grid>
            </Border>

            <!-- 使用 Popup 解决 WebView2 airspace 问题：Popup 有独立 HWND，永远在 WebView2 之上 -->
            <Popup x:Name="WorkspaceExpandPopup"
                   Grid.ColumnSpan="3"
                   Placement="Absolute"
                   AllowsTransparency="True"
                   IsOpen="False">
                <Button x:Name="ExpandWorkspaceHandle"
                        Style="{StaticResource GhostIconButton}"
                        ToolTip="Expand Workspace"
                        AutomationProperties.AutomationId="ExpandWorkspaceHandle"
                        Click="OnExpandWorkspaceHandleClicked">
                    <!-- 与面板头部同款图标（836f7a.svg） -->
                    <Path Width="14" Height="14"
                          Stretch="Uniform"
                          Fill="#4C6E8A"
                          Data="M6.835 4c-.451.004-.82.012-1.137.038-.386.032-.659.085-.876.162l-.2.086c-.44.224-.807.564-1.063.982l-.103.184c-.126.247-.206.562-.248 1.076-.043.523-.043 1.19-.043 2.135v2.664c0 .944 0 1.612.043 2.135.042.515.122.829.248 1.076l.103.184c.256.418.624.758 1.063.982l.2.086c.217.077.49.13.876.162.316.026.685.034 1.136.038zm11.33 7.327c0 .922 0 1.654-.048 2.243-.043.522-.125.977-.305 1.395l-.082.177a4 4 0 0 1-1.473 1.593l-.276.155c-.465.237-.974.338-1.57.387-.59.048-1.322.048-2.244.048H7.833c-.922 0-1.654 0-2.243-.048-.522-.042-.977-.126-1.395-.305l-.176-.082a4 4 0 0 1-1.594-1.473l-.154-.275c-.238-.466-.34-.975-.388-1.572-.048-.589-.048-1.32-.048-2.243V8.663c0-.922 0-1.654.048-2.243.049-.597.15-1.106.388-1.571l.154-.276a4 4 0 0 1 1.594-1.472l.176-.083c.418-.18.873-.263 1.395-.305.589-.048 1.32-.048 2.243-.048h4.334c.922 0 1.654 0 2.243.048.597.049 1.106.15 1.571.388l.276.154a4 4 0 0 1 1.473 1.594l.082.176c.18.418.262.873.305 1.395.048.589.048 1.32.048 2.243zm-10 4.668h4.002c.944 0 1.612 0 2.135-.043.514-.042.829-.122 1.076-.248l.184-.103c.418-.256.758-.624.982-1.063l.086-.2c.077-.217.13-.49.162-.876.043-.523.043-1.19.043-2.135V8.663c0-.944 0-1.612-.043-2.135-.032-.386-.085-.659-.162-.876l-.086-.2a2.67 2.67 0 0 0-.982-1.063l-.184-.103c-.247-.126-.562-.206-1.076-.248-.523-.043-1.19-.043-2.135-.043H8.164L8.165 4z" />
                </Button>
            </Popup>

            <Popup x:Name="OutlineExpandPopup"
                   Grid.ColumnSpan="3"
                   Placement="Absolute"
                   AllowsTransparency="True"
                   IsOpen="False">
                <Button x:Name="ExpandOutlineHandle"
                        Style="{StaticResource GhostIconButton}"
                        ToolTip="Expand Outline"
                        AutomationProperties.AutomationId="ExpandOutlineHandle"
                        Click="OnExpandOutlineHandleClicked">
                    <!-- 与面板头部同款图标（836f7a.svg），水平镜像 -->
                    <Path Width="14" Height="14"
                          Stretch="Uniform"
                          Fill="#4C6E8A"
                          Data="M6.835 4c-.451.004-.82.012-1.137.038-.386.032-.659.085-.876.162l-.2.086c-.44.224-.807.564-1.063.982l-.103.184c-.126.247-.206.562-.248 1.076-.043.523-.043 1.19-.043 2.135v2.664c0 .944 0 1.612.043 2.135.042.515.122.829.248 1.076l.103.184c.256.418.624.758 1.063.982l.2.086c.217.077.49.13.876.162.316.026.685.034 1.136.038zm11.33 7.327c0 .922 0 1.654-.048 2.243-.043.522-.125.977-.305 1.395l-.082.177a4 4 0 0 1-1.473 1.593l-.276.155c-.465.237-.974.338-1.57.387-.59.048-1.322.048-2.244.048H7.833c-.922 0-1.654 0-2.243-.048-.522-.042-.977-.126-1.395-.305l-.176-.082a4 4 0 0 1-1.594-1.473l-.154-.275c-.238-.466-.34-.975-.388-1.572-.048-.589-.048-1.32-.048-2.243V8.663c0-.922 0-1.654.048-2.243.049-.597.15-1.106.388-1.571l.154-.276a4 4 0 0 1 1.594-1.472l.176-.083c.418-.18.873-.263 1.395-.305.589-.048 1.32-.048 2.243-.048h4.334c.922 0 1.654 0 2.243.048.597.049 1.106.15 1.571.388l.276.154a4 4 0 0 1 1.473 1.594l.082.176c.18.418.262.873.305 1.395.048.589.048 1.32.048 2.243zm-10 4.668h4.002c.944 0 1.612 0 2.135-.043.514-.042.829-.122 1.076-.248l.184-.103c.418-.256.758-.624.982-1.063l.086-.2c.077-.217.13-.49.162-.876.043-.523.043-1.19.043-2.135V8.663c0-.944 0-1.612-.043-2.135-.032-.386-.085-.659-.162-.876l-.086-.2a2.67 2.67 0 0 0-.982-1.063l-.184-.103c-.247-.126-.562-.206-1.076-.248-.523-.043-1.19-.043-2.135-.043H8.164L8.165 4z">
                        <Path.LayoutTransform>
                            <ScaleTransform ScaleX="-1" />
                        </Path.LayoutTransform>
                    </Path>
                </Button>
            </Popup>
        </Grid>
    </Grid>
    </Border>
</Window>
