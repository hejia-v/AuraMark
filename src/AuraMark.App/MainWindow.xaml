        <!-- 菜单项通用样式（Role 触发器区分顶层/子项） -->
        <Style x:Key="MenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#434C5E" />
            <Setter Property="FontSize" Value="13" />
            <Style.Triggers>

                <!-- 顶层菜单按钮（File / View） -->
                <Trigger Property="Role" Value="TopLevelHeader">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="MenuItem">
                                <Grid>
                                    <Border x:Name="Bg"
                                            CornerRadius="6"
                                            Padding="10,4"
                                            Background="Transparent">
                                        <ContentPresenter ContentSource="Header"
                                                          RecognizesAccessKey="True"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                    <Popup x:Name="PART_Popup"
                                           IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                           Placement="Bottom"
                                           VerticalOffset="4"
                                           AllowsTransparency="True"
                                           Focusable="False"
                                           PopupAnimation="Fade">
                                        <Border Margin="4,0,6,8"
                                                Background="#FFFFFF"
                                                BorderBrush="#DDE3EC"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                MinWidth="188"
                                                Padding="4">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#000000"
                                                                  Opacity="0.10"
                                                                  BlurRadius="18"
                                                                  ShadowDepth="4"
                                                                  Direction="270" />
                                            </Border.Effect>
                                            <ItemsPresenter />
                                        </Border>
                                    </Popup>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#EEF1F5" />
                                    </Trigger>
                                    <Trigger Property="IsSubmenuOpen" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#E4EAF2" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>

                <!-- 下拉菜单项 -->
                <Trigger Property="Role" Value="TopLevelItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="MenuItem">
                                <Grid>
                                    <Border x:Name="Bg"
                                            CornerRadius="6"
                                            Padding="10,4"
                                            Background="Transparent">
                                        <ContentPresenter ContentSource="Header"
                                                          RecognizesAccessKey="True"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                    <Popup x:Name="PART_Popup"
                                           IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                           Placement="Bottom"
                                           VerticalOffset="4"
                                           AllowsTransparency="True"
                                           Focusable="False"
                                           PopupAnimation="Fade">
                                        <Border Margin="4,0,6,8"
                                                Background="#FFFFFF"
                                                BorderBrush="#DDE3EC"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                MinWidth="188"
                                                Padding="4">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#000000"
                                                                  Opacity="0.10"
                                                                  BlurRadius="18"
                                                                  ShadowDepth="4"
                                                                  Direction="270" />
                                            </Border.Effect>
                                            <ItemsPresenter />
                                        </Border>
                                    </Popup>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#EEF1F5" />
                                    </Trigger>
                                    <Trigger Property="IsSubmenuOpen" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#E4EAF2" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>

                <Trigger Property="Role" Value="SubmenuItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="MenuItem">
                                <Border x:Name="Bg"
                                        Background="Transparent"
                                        CornerRadius="5"
                                        Padding="10,6"
                                        Margin="0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="CheckGlyph"
                                                   Width="12"
                                                   Margin="0,0,6,0"
                                                   Text="✓"
                                                   Foreground="#6B7C93"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Opacity="0" />
                                        <ContentPresenter ContentSource="Header"
                                                          Grid.Column="1"
                                                          RecognizesAccessKey="True"
                                                          VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2"
                                                   Margin="24,0,2,0"
                                                   Text="{TemplateBinding InputGestureText}"
                                                   Foreground="#9AA4B0"
                                                   FontSize="11"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#EEF1F5" />
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="CheckGlyph" Property="Opacity" Value="1" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Foreground" Value="#B0BAC6" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>

                <!-- 带子菜单的下拉项（如 Recent） -->
                <Trigger Property="Role" Value="SubmenuHeader">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="MenuItem">
                                <Grid>
                                    <Border x:Name="Bg"
                                            Background="Transparent"
                                            CornerRadius="5"
                                            Padding="10,6"
                                            Margin="0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter ContentSource="Header"
                                                              RecognizesAccessKey="True"
                                                              VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="›"
                                                       Margin="16,0,2,0"
                                                       Foreground="#9AA4B0"
                                                       FontSize="16"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                    <Popup x:Name="PART_Popup"
                                           IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                           Placement="Right"
                                           HorizontalOffset="-4"
                                           VerticalOffset="-8"
                                           AllowsTransparency="True"
                                           Focusable="False"
                                           PopupAnimation="Fade">
                                        <Border Margin="0,0,6,8"
                                                Background="#FFFFFF"
                                                BorderBrush="#DDE3EC"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                MinWidth="280"
                                                Padding="4">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#000000"
                                                                  Opacity="0.10"
                                                                  BlurRadius="18"
                                                                  ShadowDepth="4"
                                                                  Direction="270" />
                                            </Border.Effect>
                                            <ItemsPresenter />
                                        </Border>
                                    </Popup>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#EEF1F5" />
                                    </Trigger>
                                    <Trigger Property="IsSubmenuOpen" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#E4EAF2" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Foreground" Value="#B0BAC6" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>

            </Style.Triggers>
        </Style>

        <!-- 下拉菜单分隔线样式 -->
        <Style x:Key="MenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="8,3" />
            <Setter Property="Background" Value="#E8ECF2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1"
                                Background="{TemplateBinding Background}"
                                Margin="{TemplateBinding Margin}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border BorderBrush="#38000000"
            BorderThickness="1"
            CornerRadius="12"
            ClipToBounds="True">
    <Grid x:Name="WindowRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="TopBar"
                Grid.Row="0"
                Background="#F3F4F6"
                BorderBrush="#1A434C5E"
                BorderThickness="0,0,0,1"
                Opacity="1"
                MouseLeftButtonDown="OnTopBarMouseLeftButtonDown">
            <Grid Margin="14,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Menu Style="{StaticResource TopBarMenuStyle}"
                      shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <MenuItem x:Name="FileMenuRoot" Header="File" Style="{StaticResource MenuItemStyle}">
                        <MenuItem x:Name="FileNewMenuItem" Header="New"
                                  Style="{StaticResource MenuItemStyle}"
                                  InputGestureText="Ctrl+N"
                                  Click="OnNewFileClicked" />
                        <MenuItem x:Name="FileOpenFileMenuItem" Header="Open File..."
                                  Style="{StaticResource MenuItemStyle}"
                                  InputGestureText="Ctrl+O"
                                  Click="OnOpenFileClicked" />
                        <MenuItem x:Name="FileOpenFolderMenuItem" Header="Open Folder..."
                                  Style="{StaticResource MenuItemStyle}"
                                  Click="OnOpenFolderClicked" />
                        <Separator Style="{StaticResource MenuSeparatorStyle}" />
                        <MenuItem x:Name="RecentMenuItem"
                                  Header="Recent"
                                  Style="{StaticResource MenuItemStyle}" />
                        <Separator Style="{StaticResource MenuSeparatorStyle}" />
                        <MenuItem x:Name="FileSaveMenuItem" Header="Save"
                                  Style="{StaticResource MenuItemStyle}"
                                  InputGestureText="Ctrl+S"
                                  Click="OnSaveNowClicked" />
                        <Separator Style="{StaticResource MenuSeparatorStyle}" />
                        <MenuItem x:Name="FileSettingsMenuItem"
                                  Header="Settings"
                                  Style="{StaticResource MenuItemStyle}"
                                  Click="OnOpenSettingsClicked" />
                    </MenuItem>
                    <MenuItem x:Name="EditMenuRoot" Header="Edit" Style="{StaticResource MenuItemStyle}">
                        <MenuItem x:Name="UndoMenuItem"
                                  Header="Undo"
                                  Style="{StaticResource MenuItemStyle}"
                                  InputGestureText="Ctrl+Z"
                                  IsEnabled="False"
                                  Click="OnUndoClicked" />
                        <MenuItem x:Name="RedoMenuItem"
                                  Header="Redo"
                                  Style="{StaticResource MenuItemStyle}"
                                  InputGestureText="Ctrl+Y"
                                  IsEnabled="False"
                                  Click="OnRedoClicked" />
                    </MenuItem>
                    <MenuItem x:Name="ParagraphMenuRoot" Header="Paragraph" Style="{StaticResource MenuItemStyle}" />
                    <MenuItem x:Name="FormatMenuRoot" Header="Format" Style="{StaticResource MenuItemStyle}" />
                    <MenuItem x:Name="ViewMenuRoot" Header="View" Style="{StaticResource MenuItemStyle}">
                        <MenuItem x:Name="ViewToggleWorkspaceMenuItem" Header="Toggle Workspace"
                                  Style="{StaticResource MenuItemStyle}"
                                  InputGestureText="Ctrl+Shift+L"
                                  Click="OnToggleSidebarClicked" />
                        <MenuItem x:Name="ViewToggleOutlineMenuItem" Header="Toggle Outline"
                                  Style="{StaticResource MenuItemStyle}"
                                  InputGestureText="Ctrl+Shift+O"
                                  Click="OnToggleOutlineClicked" />
                    </MenuItem>
                </Menu>

                <Grid Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="FileNameText"
                                   Margin="0,0,12,0"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#434C5E"
                                   AutomationProperties.AutomationId="CurrentFileNameText"
                                   Visibility="Collapsed"
                                   Text="Untitled.md" />
                        <TextBlock x:Name="StateText"
                                   FontSize="12"
                                   Foreground="#8C434C5E"
                                   Visibility="Collapsed"
                                   Text="Idle" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Button x:Name="OpenHistoryBackButton"
                                Width="24"
                                Padding="0"
                                Margin="0,0,6,0"
                                Style="{StaticResource TopBarActionButtonStyle}"
                                Click="OnOpenHistoryBackButtonClicked"
                                ToolTip="Back"
                                AutomationProperties.AutomationId="OpenHistoryBackButton"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Path Width="12"
                                  Height="12"
                                  Stretch="Uniform"
                                  Fill="#738196"
                                  Data="M13.7,4.3 L6,12 L13.7,19.7 L15.1,18.3 L8.8,12 L15.1,5.7 Z" />
                        </Button>

                        <Button x:Name="OpenHistoryForwardButton"
                                Width="24"
                                Padding="0"
                                Margin="0,0,6,0"
                                Style="{StaticResource TopBarActionButtonStyle}"
                                Click="OnOpenHistoryForwardButtonClicked"
                                ToolTip="Forward"
                                AutomationProperties.AutomationId="OpenHistoryForwardButton"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Path Width="12"
                                  Height="12"
                                  Stretch="Uniform"
                                  Fill="#738196"
                                  Data="M10.3,4.3 L18,12 L10.3,19.7 L8.9,18.3 L15.2,12 L8.9,5.7 Z" />
                        </Button>

                        <Button x:Name="QuickOpenButton"
                                Style="{StaticResource QuickOpenButtonStyle}"
                                Click="OnQuickOpenButtonClicked"
                                ToolTip="Quick Open (Ctrl+P)"
