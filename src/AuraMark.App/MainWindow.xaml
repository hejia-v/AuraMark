<Window x:Class="AuraMark.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:AuraMark.App.Models"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="AuraMark"
        Icon="app.ico"
        Width="1280"
        Height="800"
        MinWidth="980"
        MinHeight="640"
        Background="#F9FAFB"
        WindowStyle="None"
        ResizeMode="CanResize"
        PreviewKeyDown="OnWindowPreviewKeyDown"
        MouseMove="OnWindowMouseMove">
    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="12"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <HierarchicalDataTemplate DataType="{x:Type models:FileTreeNode}" ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding Name}" />
        </HierarchicalDataTemplate>

        <!-- 圆形图标按钮 Style -->
        <Style x:Key="CircularIconButton" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#B8C8D8" />
            <Setter Property="Background" Value="#E8EEF4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#C8DCEA" />
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#81A1C1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#AECBE0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 无背景浮动图标按钮 Style（用于展开面板的 Popup 按钮） -->
        <Style x:Key="GhostIconButton" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#28434C5E" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#45434C5E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 面板标题栏图标按钮 Style（圆角矩形，22×22） -->
        <Style x:Key="PanelIconButton" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#20434C5E" />
                                <Setter TargetName="Bg" Property="BorderBrush" Value="#35434C5E" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#38434C5E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 窗口最小化按钮 Style -->
        <Style x:Key="WindowMinimizeButton" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="22" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <TextBlock x:Name="Icon"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="—"
                                       FontSize="12"
                                       Foreground="#8090A4" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#E2E8F0" />
                                <Setter TargetName="Icon" Property="Foreground" Value="#3D4A5C" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#CBD5E1" />
                                <Setter TargetName="Icon" Property="Foreground" Value="#3D4A5C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 窗口关闭按钮 Style -->
        <Style x:Key="WindowCloseButton" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="22" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <TextBlock x:Name="Icon"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="✕"
                                       FontSize="11"
                                       Foreground="#8090A4" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#E05252" />
                                <Setter TargetName="Icon" Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#C03838" />
                                <Setter TargetName="Icon" Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 顶栏 Menu 容器样式 -->
        <Style x:Key="TopBarMenuStyle" TargetType="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- 菜单项通用样式（Role 触发器区分顶层/子项） -->
        <Style x:Key="MenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#434C5E" />
            <Setter Property="FontSize" Value="13" />
            <Style.Triggers>

                <!-- 顶层菜单按钮（File / View） -->
                <Trigger Property="Role" Value="TopLevelHeader">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="MenuItem">
                                <Grid>
                                    <Border x:Name="Bg"
                                            CornerRadius="6"
                                            Padding="10,4"
                                            Background="Transparent">
                                        <ContentPresenter ContentSource="Header"
                                                          RecognizesAccessKey="True"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                    <Popup x:Name="PART_Popup"
                                           IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                           Placement="Bottom"
                                           VerticalOffset="4"
                                           AllowsTransparency="True"
                                           Focusable="False"
                                           PopupAnimation="Fade">
                                        <Border Margin="4,0,6,8"
                                                Background="#FFFFFF"
                                                BorderBrush="#DDE3EC"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                MinWidth="188"
                                                Padding="4">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#000000"
                                                                  Opacity="0.10"
                                                                  BlurRadius="18"
                                                                  ShadowDepth="4"
                                                                  Direction="270" />
                                            </Border.Effect>
                                            <ItemsPresenter />
                                        </Border>
                                    </Popup>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#EEF1F5" />
                                    </Trigger>
                                    <Trigger Property="IsSubmenuOpen" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#E4EAF2" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>

                <!-- 下拉菜单项 -->
                <Trigger Property="Role" Value="SubmenuItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="MenuItem">
                                <Border x:Name="Bg"
                                        Background="Transparent"
                                        CornerRadius="5"
                                        Padding="10,6"
                                        Margin="0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter ContentSource="Header"
                                                          RecognizesAccessKey="True"
                                                          VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Margin="24,0,2,0"
                                                   Text="{TemplateBinding InputGestureText}"
                                                   Foreground="#9AA4B0"
                                                   FontSize="11"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#EEF1F5" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Foreground" Value="#B0BAC6" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>

                <!-- 带子菜单的下拉项（如 Recent） -->
                <Trigger Property="Role" Value="SubmenuHeader">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="MenuItem">
                                <Grid>
                                    <Border x:Name="Bg"
                                            Background="Transparent"
                                            CornerRadius="5"
                                            Padding="10,6"
                                            Margin="0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter ContentSource="Header"
                                                              RecognizesAccessKey="True"
                                                              VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="›"
                                                       Margin="16,0,2,0"
                                                       Foreground="#9AA4B0"
                                                       FontSize="16"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                    <Popup x:Name="PART_Popup"
                                           IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                           Placement="Right"
                                           HorizontalOffset="-4"
                                           VerticalOffset="-8"
                                           AllowsTransparency="True"
                                           Focusable="False"
                                           PopupAnimation="Fade">
                                        <Border Margin="0,0,6,8"
                                                Background="#FFFFFF"
                                                BorderBrush="#DDE3EC"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                MinWidth="280"
                                                Padding="4">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#000000"
                                                                  Opacity="0.10"
                                                                  BlurRadius="18"
                                                                  ShadowDepth="4"
                                                                  Direction="270" />
                                            </Border.Effect>
                                            <ItemsPresenter />
                                        </Border>
                                    </Popup>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#EEF1F5" />
                                    </Trigger>
                                    <Trigger Property="IsSubmenuOpen" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#E4EAF2" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Foreground" Value="#B0BAC6" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>

            </Style.Triggers>
        </Style>

        <!-- 下拉菜单分隔线样式 -->
        <Style x:Key="MenuSeparatorStyle" TargetType="Separator">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="8,3" />
            <Setter Property="Background" Value="#E8ECF2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1"
                                Background="{TemplateBinding Background}"
                                Margin="{TemplateBinding Margin}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border BorderBrush="#38000000"
            BorderThickness="1"
            CornerRadius="12"
            ClipToBounds="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="TopBar"
                Grid.Row="0"
                Background="#F3F4F6"
                BorderBrush="#1A434C5E"
                BorderThickness="0,0,0,1"
                Opacity="1"
                MouseLeftButtonDown="OnTopBarMouseLeftButtonDown">
            <Grid Margin="14,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Menu Style="{StaticResource TopBarMenuStyle}"
                      shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <MenuItem Header="File" Style="{StaticResource MenuItemStyle}">
                        <MenuItem Header="New"
                                  Style="{StaticResource MenuItemStyle}"
                                  InputGestureText="Ctrl+N"
                                  Click="OnNewFileClicked" />
                        <MenuItem Header="Open File…"
                                  Style="{StaticResource MenuItemStyle}"
                                  InputGestureText="Ctrl+O"
                                  Click="OnOpenFileClicked" />
                        <MenuItem Header="Open Folder…"
                                  Style="{StaticResource MenuItemStyle}"
                                  Click="OnOpenFolderClicked" />
                        <Separator Style="{StaticResource MenuSeparatorStyle}" />
                        <MenuItem x:Name="RecentMenuItem"
                                  Header="Recent"
                                  Style="{StaticResource MenuItemStyle}" />
                        <Separator Style="{StaticResource MenuSeparatorStyle}" />
                        <MenuItem Header="Save"
                                  Style="{StaticResource MenuItemStyle}"
                                  InputGestureText="Ctrl+S"
                                  Click="OnSaveNowClicked" />
                        <Separator Style="{StaticResource MenuSeparatorStyle}" />
                        <MenuItem Header="Export…"
                                  Style="{StaticResource MenuItemStyle}"
                                  Click="OnExportHtmlClicked" />
                    </MenuItem>
                    <MenuItem Header="View" Style="{StaticResource MenuItemStyle}">
                        <MenuItem Header="Toggle Workspace"
                                  Style="{StaticResource MenuItemStyle}"
                                  InputGestureText="Ctrl+Shift+L"
                                  Click="OnToggleSidebarClicked" />
                        <MenuItem Header="Toggle Outline"
                                  Style="{StaticResource MenuItemStyle}"
                                  InputGestureText="Ctrl+Shift+O"
                                  Click="OnToggleOutlineClicked" />
                    </MenuItem>
                </Menu>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock x:Name="FileNameText"
                               Margin="0,0,12,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#434C5E"
                               Text="Untitled.md" />
                    <TextBlock x:Name="StateText"
                               FontSize="12"
                               Foreground="#8C434C5E"
                               Text="Idle" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <Button x:Name="MinimizeButton"
                            Style="{StaticResource WindowMinimizeButton}"
                            Margin="0,0,2,0"
                            Click="OnMinimizeClicked"
                            ToolTip="Minimize"
                            AutomationProperties.AutomationId="WindowMinimizeButton"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                    <Button x:Name="CloseButton"
                            Style="{StaticResource WindowCloseButton}"
                            Click="OnCloseClicked"
                            ToolTip="Close"
                            AutomationProperties.AutomationId="WindowCloseButton"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border x:Name="SidebarContainer"
                    Width="0"
                    Background="#F3F4F6"
                    BorderBrush="#1A434C5E"
                    BorderThickness="0,0,1,0"
                    Opacity="0"
                    Visibility="Collapsed">
                <Grid Margin="10,10,8,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#8C434C5E"
                                   Text="WORKSPACE" />
                        <Button Grid.Column="1"
                                Style="{StaticResource PanelIconButton}"
                                Click="OnToggleSidebarClicked"
                                ToolTip="Toggle Workspace (Ctrl+Shift+L)">
                            <!-- 面板布局图标（836f7a.svg，20×20 坐标系） -->
                            <Path Width="14" Height="14"
                                  Stretch="Uniform"
                                  Fill="#5E6E82"
                                  Data="M6.835 4c-.451.004-.82.012-1.137.038-.386.032-.659.085-.876.162l-.2.086c-.44.224-.807.564-1.063.982l-.103.184c-.126.247-.206.562-.248 1.076-.043.523-.043 1.19-.043 2.135v2.664c0 .944 0 1.612.043 2.135.042.515.122.829.248 1.076l.103.184c.256.418.624.758 1.063.982l.2.086c.217.077.49.13.876.162.316.026.685.034 1.136.038zm11.33 7.327c0 .922 0 1.654-.048 2.243-.043.522-.125.977-.305 1.395l-.082.177a4 4 0 0 1-1.473 1.593l-.276.155c-.465.237-.974.338-1.57.387-.59.048-1.322.048-2.244.048H7.833c-.922 0-1.654 0-2.243-.048-.522-.042-.977-.126-1.395-.305l-.176-.082a4 4 0 0 1-1.594-1.473l-.154-.275c-.238-.466-.34-.975-.388-1.572-.048-.589-.048-1.32-.048-2.243V8.663c0-.922 0-1.654.048-2.243.049-.597.15-1.106.388-1.571l.154-.276a4 4 0 0 1 1.594-1.472l.176-.083c.418-.18.873-.263 1.395-.305.589-.048 1.32-.048 2.243-.048h4.334c.922 0 1.654 0 2.243.048.597.049 1.106.15 1.571.388l.276.154a4 4 0 0 1 1.473 1.594l.082.176c.18.418.262.873.305 1.395.048.589.048 1.32.048 2.243zm-10 4.668h4.002c.944 0 1.612 0 2.135-.043.514-.042.829-.122 1.076-.248l.184-.103c.418-.256.758-.624.982-1.063l.086-.2c.077-.217.13-.49.162-.876.043-.523.043-1.19.043-2.135V8.663c0-.944 0-1.612-.043-2.135-.032-.386-.085-.659-.162-.876l-.086-.2a2.67 2.67 0 0 0-.982-1.063l-.184-.103c-.247-.126-.562-.206-1.076-.248-.523-.043-1.19-.043-2.135-.043H8.164L8.165 4z" />
                        </Button>
                    </Grid>

                    <TreeView x:Name="FileTreeView"
                              Grid.Row="1"
                              Margin="0,6,0,0"
                              BorderThickness="0"
                              Background="#00000000"
                              Foreground="#434C5E"
                              ItemsSource="{Binding FileTreeNodes}"
                              SelectedItemChanged="OnFileTreeSelectionChanged" />
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <wv2:WebView2 x:Name="MainWebView" Margin="14,10,14,14" />

                <Border x:Name="LoadingOverlay"
                        Margin="30,26,30,30"
                        Padding="18"
                        Background="#F2F9FAFB"
                        BorderBrush="#33434C5E"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="LoadingText"
                                   HorizontalAlignment="Center"
                                   FontSize="13"
                                   Foreground="#8C434C5E"
                                   Text="Loading document..." />
                        <ProgressBar Margin="0,12,0,0"
                                     Height="5"
                                     IsIndeterminate="True"
                                     Foreground="#81A1C1" />
                    </StackPanel>
                </Border>

                <Border x:Name="ErrorToast"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,16,22,0"
                        Padding="10,8"
                        Background="#33BF616A"
                        BorderBrush="#66BF616A"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="Collapsed"
                        Opacity="0">
                    <DockPanel>
                        <TextBlock x:Name="ErrorText"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   Foreground="#8F2D37"
                                   FontSize="12"
                                   Text="Save failed." />
                        <Button x:Name="RetrySaveButton"
                                Width="54"
                                Height="22"
                                BorderThickness="0"
                                Background="#99FFFFFF"
                                Foreground="#8F2D37"
                                AutomationProperties.AutomationId="RetrySaveButton"
                                Click="OnRetrySaveClicked"
                                Content="Retry" />
                    </DockPanel>
                </Border>

                <Border x:Name="SyncConflictToast"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,62,22,0"
                        Padding="10,8"
                        Background="#335E81AC"
                        BorderBrush="#665E81AC"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="Collapsed"
                        Opacity="0">
                    <DockPanel>
                        <TextBlock x:Name="SyncConflictText"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   Foreground="#3A4A63"
                                   FontSize="12"
                                   Text="External file changed. Keep local or reload external?" />
                        <Button x:Name="KeepLocalButton"
                                Width="72"
                                Height="22"
                                Margin="0,0,6,0"
                                BorderThickness="0"
                                Background="#99FFFFFF"
                                Foreground="#3A4A63"
                                AutomationProperties.AutomationId="KeepLocalButton"
                                Click="OnKeepLocalClicked"
                                Content="Keep Local" />
                        <Button x:Name="AcceptExternalButton"
                                Width="92"
                                Height="22"
                                BorderThickness="0"
                                Background="#99FFFFFF"
                                Foreground="#3A4A63"
                                AutomationProperties.AutomationId="AcceptExternalButton"
                                Click="OnAcceptExternalClicked"
                                Content="Use External" />
                    </DockPanel>
                </Border>

                <Border x:Name="SavingDot"
                        Width="9"
                        Height="9"
                        CornerRadius="4.5"
                        Background="#81A1C1"
                        Opacity="0.4"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,20,20"
                        Visibility="Collapsed" />
            </Grid>

            <Border x:Name="OutlineContainer"
                    Grid.Column="2"
                    Width="0"
