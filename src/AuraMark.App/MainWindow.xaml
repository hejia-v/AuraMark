                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Grid Margin="10,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Path Width="14"
                                      Height="14"
                                      Margin="0,0,6,0"
                                      VerticalAlignment="Center"
                                      Stretch="Uniform"
                                      Fill="#677489"
                                      Data="M10.5 3a7.5 7.5 0 0 1 5.645 12.438l4.709 4.708a.5.5 0 0 1-.708.708l-4.708-4.709A7.5 7.5 0 1 1 10.5 3zm0 1.5a6 6 0 1 0 0 12 6 6 0 0 0 0-12z" />
                                <TextBlock Grid.Column="1"
                                           x:Name="QuickOpenButtonText"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="#677489"
                                           Text="Search files" />
                                <Border Grid.Column="2"
                                        Padding="5,1"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Background="#EEF2F7"
                                        BorderBrush="#D8E0EA"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <TextBlock FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="#7A879A"
                                               Text="Ctrl+P" />
                                </Border>
                            </Grid>
                        </Button>

                        <Button x:Name="RecentFilesButton"
                                Width="24"
                                Height="24"
                                Margin="6,0,0,0"
                                Padding="0"
                                BorderThickness="1"
                                BorderBrush="#CDD6E1"
                                Background="#FAFBFC"
                                Cursor="Hand"
                                ToolTip="Recent Files"
                                Click="OnRecentFilesButtonClicked"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bg"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="7">
                                        <Path Width="12"
                                              Height="12"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Stretch="Uniform"
                                              Fill="#738196"
                                              Data="M12 2C6.486 2 2 6.486 2 12s4.486 10 10 10 10-4.486 10-10S17.514 2 12 2zm0 18c-4.411 0-8-3.589-8-8s3.589-8 8-8 8 3.589 8 8-3.589 8-8 8zm1-13h-2v6l5.25 3.15.75-1.23-4-2.42V7z" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#FFFFFF" />
                                            <Setter TargetName="Bg" Property="BorderBrush" Value="#B9C5D2" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#EDF2F7" />
                                            <Setter TargetName="Bg" Property="BorderBrush" Value="#AEBCCB" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="SkillsButton"
                                Width="24"
                                Padding="0"
                                Margin="6,0,6,0"
                                Style="{StaticResource TopBarActionButtonStyle}"
                                Click="OnSkillsButtonClicked"
                                ToolTip="Skills"
                                AutomationProperties.AutomationId="SkillsButton"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Path Width="13"
                                  Height="13"
                                  Stretch="Uniform"
                                  Fill="#738196"
                                  Data="{StaticResource SkillFolderIconGeometry}" />
                        </Button>

                        <Button x:Name="WorkspaceAgentsButton"
                                Width="24"
                                Padding="0"
                                Margin="0,0,6,0"
                                Style="{StaticResource TopBarActionButtonStyle}"
                                Click="OnWorkspaceAgentsButtonClicked"
                                ToolTip="Open AGENTS.md"
                                AutomationProperties.AutomationId="WorkspaceAgentsButton"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Viewbox Width="14"
                                     Height="14"
                                     Stretch="Uniform">
                                <Path Fill="#111111"
                                      Data="{StaticResource OpenAiIconGeometry}" />
                            </Viewbox>
                        </Button>

                        <Button x:Name="WorkspaceClaudeButton"
                                Width="24"
                                Padding="0"
                                Margin="0,0,6,0"
                                Style="{StaticResource TopBarActionButtonStyle}"
                                Click="OnWorkspaceClaudeButtonClicked"
                                ToolTip="Open CLAUDE.md"
                                AutomationProperties.AutomationId="WorkspaceClaudeButton"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Viewbox Width="14"
                                     Height="14"
                                     Stretch="Uniform">
                                <Path Fill="#D97757"
                                      Data="M4.709 15.955l4.72-2.647.08-.23-.08-.128H9.2l-.79-.048-2.698-.073-2.339-.097-2.266-.122-.571-.121L0 11.784l.055-.352.48-.321.686.06 1.52.103 2.278.158 1.652.097 2.449.255h.389l.055-.157-.134-.098-.103-.097-2.358-1.596-2.552-1.688-1.336-.972-.724-.491-.364-.462-.158-1.008.656-.722.881.06.225.061.893.686 1.908 1.476 2.491 1.833.365.304.145-.103.019-.073-.164-.274-1.355-2.446-1.446-2.49-.644-1.032-.17-.619a2.97 2.97 0 01-.104-.729L6.283.134 6.696 0l.996.134.42.364.62 1.414 1.002 2.229 1.555 3.03.456.898.243.832.091.255h.158V9.01l.128-1.706.237-2.095.23-2.695.08-.76.376-.91.747-.492.584.28.48.685-.067.444-.286 1.851-.559 2.903-.364 1.942h.212l.243-.242.985-1.306 1.652-2.064.73-.82.85-.904.547-.431h1.033l.76 1.129-.34 1.166-1.064 1.347-.881 1.142-1.264 1.7-.79 1.36.073.11.188-.02 2.856-.606 1.543-.28 1.841-.315.833.388.091.395-.328.807-1.969.486-2.309.462-3.439.813-.042.03.049.061 1.549.146.662.036h1.622l3.02.225.79.522.474.638-.079.485-1.215.62-1.64-.389-3.829-.91-1.312-.329h-.182v.11l1.093 1.068 2.006 1.81 2.509 2.33.127.578-.322.455-.34-.049-2.205-1.657-.851-.747-1.926-1.62h-.128v.17l.444.649 2.345 3.521.122 1.08-.17.353-.608.213-.668-.122-1.374-1.925-1.415-2.167-1.143-1.943-.14.08-.674 7.254-.316.37-.729.28-.607-.461-.322-.747.322-1.476.389-1.924.315-1.53.286-1.9.17-.632-.012-.042-.14.018-1.434 1.967-2.18 2.945-1.726 1.845-.414.164-.717-.37.067-.662.401-.589 2.388-3.036 1.44-1.882.93-1.086-.006-.158h-.055L4.132 18.56l-1.13.146-.487-.456.061-.746.231-.243 1.908-1.312-.006.006z" />
                            </Viewbox>
                        </Button>

                        <Button x:Name="LocateCurrentFileButton"
                                Width="24"
                                Padding="0"
                                Margin="0,0,10,0"
                                Style="{StaticResource TopBarActionButtonStyle}"
                                Click="OnLocateCurrentFileButtonClicked"
                                ToolTip="Locate current file"
                                AutomationProperties.AutomationId="LocateCurrentFileButton"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Path Width="14"
                                  Height="14"
                                  Stretch="Uniform"
                                  Fill="#738196"
                                  Data="M11 2a1 1 0 0 1 1 1v1.05a8.001 8.001 0 0 1 6.95 6.95H20a1 1 0 1 1 0 2h-1.05a8.001 8.001 0 0 1-6.95 6.95V21a1 1 0 1 1-2 0v-1.05a8.001 8.001 0 0 1-6.95-6.95H2a1 1 0 1 1 0-2h1.05a8.001 8.001 0 0 1 6.95-6.95V3a1 1 0 0 1 1-1m0 4a6 6 0 1 0 0 12 6 6 0 0 0 0-12m0 3a3 3 0 1 1 0 6 3 3 0 0 1 0-6" />
                        </Button>

                        <ToggleButton x:Name="SourceModeToggleButton"
                                      Style="{StaticResource TopBarToggleButtonStyle}"
                                      Click="OnSourceModeToggleButtonClicked"
                                      ToolTip="Markdown source"
                                      AutomationProperties.AutomationId="SourceModeToggleButton"
                                      shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <TextBlock x:Name="SourceModeToggleButtonText"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Text="Source" />
                        </ToggleButton>

                        <Popup x:Name="QuickOpenPopup"
                               PlacementTarget="{Binding ElementName=QuickOpenButton}"
                               Placement="Bottom"
                               VerticalOffset="8"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               StaysOpen="False"
                               Opened="OnQuickOpenPopupOpened"
                               Closed="OnQuickOpenPopupClosed">
                            <Border Width="460"
                                    x:Name="QuickOpenPopupSurface"
                                    Background="#FFFFFF"
                                    BorderBrush="#DCE4EE"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000"
                                                      Opacity="0.12"
                                                      BlurRadius="24"
                                                      ShadowDepth="6"
                                                      Direction="270" />
                                </Border.Effect>
                                <Grid MaxHeight="420">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Border Background="#F5F7FA"
                                            BorderBrush="#DCE4EE"
                                            BorderThickness="1"
                                            CornerRadius="9"
                                            Padding="10,7">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Path Width="14"
                                                  Height="14"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center"
                                                  Stretch="Uniform"
                                                  Fill="#738196"
                                                  Data="M10.5 3a7.5 7.5 0 0 1 5.645 12.438l4.709 4.708a.5.5 0 0 1-.708.708l-4.708-4.709A7.5 7.5 0 1 1 10.5 3zm0 1.5a6 6 0 1 0 0 12 6 6 0 0 0 0-12z" />
                                            <Grid Grid.Column="1">
                                                <TextBox x:Name="QuickOpenSearchTextBox"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         FontSize="13"
                                                         Foreground="#2F3947"
                                                         VerticalContentAlignment="Center"
                                                         TextChanged="OnQuickOpenSearchTextChanged"
                                                         PreviewKeyDown="OnQuickOpenSearchPreviewKeyDown" />
                                                <TextBlock x:Name="QuickOpenPlaceholderText"
                                                           Margin="1,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="#8A96A7"
                                                           IsHitTestVisible="False"
                                                           Text="Type a file name or path" />
                                            </Grid>
                                            <TextBlock Grid.Column="2"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"
                                                       FontSize="11"
                                                       Foreground="#8A96A7"
                                                       Text="Esc" />
                                        </Grid>
                                    </Border>

                                    <TextBlock x:Name="QuickOpenHelperText"
                                               Grid.Row="1"
                                               Margin="2,8,2,8"
                                               FontSize="11"
                                               Foreground="#7C8898"
                                               Text="Open files from the current workspace" />

                                    <Border Grid.Row="2"
                                            Background="#FFFFFF"
                                            CornerRadius="10">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock x:Name="QuickOpenEmptyStateText"
                                                       Margin="16"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       Foreground="#8A96A7"
                                                       Text="No files found."
                                                       Visibility="Collapsed" />
                                            <ListBox x:Name="QuickOpenResultsList"
                                                     Grid.RowSpan="2"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     ItemContainerStyle="{StaticResource QuickOpenResultItemStyle}"
                                                     ItemsSource="{Binding QuickOpenEntries}"
                                                     PreviewMouseLeftButtonUp="OnQuickOpenResultsMouseLeftButtonUp"
                                                     SelectionMode="Single">
                                                <ListBox.Template>
                                                    <ControlTemplate TargetType="ListBox">
                                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                                      HorizontalScrollBarVisibility="Disabled"
                                                                      Focusable="False">
                                                            <ScrollViewer.Resources>
                                                                <Style TargetType="ScrollBar" BasedOn="{StaticResource QuickOpenVerticalScrollBarStyle}" />
                                                            </ScrollViewer.Resources>
                                                            <ItemsPresenter />
                                                        </ScrollViewer>
                                                    </ControlTemplate>
                                                </ListBox.Template>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type models:QuickOpenEntry}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <Border Width="28"
                                                                    Height="28"
                                                                    Margin="0,0,10,0"
                                                                    VerticalAlignment="Center"
                                                                    Background="#F3F6F9"
                                                                    BorderBrush="#E1E7EF"
                                                                    BorderThickness="1"
                                                                    CornerRadius="7">
                                                                <Path Width="14"
                                                                      Height="14"
                                                                      VerticalAlignment="Center"
                                                                      HorizontalAlignment="Center"
                                                                      Stretch="Uniform"
                                                                      Fill="#6F7F93"
                                                                      Data="{StaticResource FileIconGeometry}" />
                                                            </Border>

                                                            <StackPanel Grid.Column="1"
                                                                        VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           FontSize="13"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#2F3947"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding DetailText}"
                                                                           Margin="0,2,0,0"
                                                                           FontSize="11"
                                                                           Foreground="#7F8A9A"
                                                                           TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>

                                                            <Border Grid.Column="2"
                                                                    Margin="10,0,0,0"
                                                                    Padding="7,2"
                                                                    VerticalAlignment="Top"
                                                                    Background="#EEF2F7"
                                                                    BorderBrush="#DAE2EB"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10">
                                                                <TextBlock Text="{Binding SourceLabel}"
                                                                           FontSize="10"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#738196" />
                                                            </Border>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>

                                            <Border x:Name="QuickOpenLoadingOverlay"
                                                    Grid.RowSpan="2"
                                                    Background="#F5F8FBF2"
                                                    CornerRadius="10"
                                                    Visibility="Collapsed">
                                                <StackPanel HorizontalAlignment="Center"
                                                            VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Center"
                                                                Margin="0,0,0,8">
                                                        <StackPanel.Triggers>
                                                            <EventTrigger RoutedEvent="StackPanel.Loaded">
                                                                <BeginStoryboard>
                                                                    <Storyboard RepeatBehavior="Forever">
                                                                        <!-- Dot1: peak at t=0.15s -->
                                                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot1"
                                                                                                      Storyboard.TargetProperty="Opacity"
                                                                                                      Duration="0:0:1.2">
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.25" />
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:0.15" Value="1.0" />
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:0.30" Value="0.25" />
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="0.25" />
                                                                        </DoubleAnimationUsingKeyFrames>
                                                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot1Transform"
                                                                                                      Storyboard.TargetProperty="Y"
                                                                                                      Duration="0:0:1.2">
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                                                            <EasingDoubleKeyFrame KeyTime="0:0:0.15" Value="-4">
                                                                                <EasingDoubleKeyFrame.EasingFunction>
                                                                                    <SineEase EasingMode="EaseOut" />
                                                                                </EasingDoubleKeyFrame.EasingFunction>
                                                                            </EasingDoubleKeyFrame>
                                                                            <EasingDoubleKeyFrame KeyTime="0:0:0.30" Value="0">
                                                                                <EasingDoubleKeyFrame.EasingFunction>
                                                                                    <SineEase EasingMode="EaseIn" />
                                                                                </EasingDoubleKeyFrame.EasingFunction>
                                                                            </EasingDoubleKeyFrame>
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="0" />
                                                                        </DoubleAnimationUsingKeyFrames>
                                                                        <!-- Dot2: peak at t=0.45s -->
                                                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot2"
                                                                                                      Storyboard.TargetProperty="Opacity"
                                                                                                      Duration="0:0:1.2">
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.25" />
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:0.30" Value="0.25" />
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:0.45" Value="1.0" />
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:0.60" Value="0.25" />
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="0.25" />
                                                                        </DoubleAnimationUsingKeyFrames>
                                                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot2Transform"
                                                                                                      Storyboard.TargetProperty="Y"
                                                                                                      Duration="0:0:1.2">
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:0.30" Value="0" />
                                                                            <EasingDoubleKeyFrame KeyTime="0:0:0.45" Value="-4">
                                                                                <EasingDoubleKeyFrame.EasingFunction>
                                                                                    <SineEase EasingMode="EaseOut" />
                                                                                </EasingDoubleKeyFrame.EasingFunction>
                                                                            </EasingDoubleKeyFrame>
                                                                            <EasingDoubleKeyFrame KeyTime="0:0:0.60" Value="0">
                                                                                <EasingDoubleKeyFrame.EasingFunction>
                                                                                    <SineEase EasingMode="EaseIn" />
                                                                                </EasingDoubleKeyFrame.EasingFunction>
                                                                            </EasingDoubleKeyFrame>
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="0" />
                                                                        </DoubleAnimationUsingKeyFrames>
                                                                        <!-- Dot3: peak at t=0.75s -->
                                                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot3"
                                                                                                      Storyboard.TargetProperty="Opacity"
                                                                                                      Duration="0:0:1.2">
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.25" />
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:0.60" Value="0.25" />
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:0.75" Value="1.0" />
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:0.90" Value="0.25" />
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="0.25" />
                                                                        </DoubleAnimationUsingKeyFrames>
                                                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot3Transform"
                                                                                                      Storyboard.TargetProperty="Y"
                                                                                                      Duration="0:0:1.2">
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:0.60" Value="0" />
                                                                            <EasingDoubleKeyFrame KeyTime="0:0:0.75" Value="-4">
                                                                                <EasingDoubleKeyFrame.EasingFunction>
                                                                                    <SineEase EasingMode="EaseOut" />
                                                                                </EasingDoubleKeyFrame.EasingFunction>
                                                                            </EasingDoubleKeyFrame>
                                                                            <EasingDoubleKeyFrame KeyTime="0:0:0.90" Value="0">
                                                                                <EasingDoubleKeyFrame.EasingFunction>
                                                                                    <SineEase EasingMode="EaseIn" />
                                                                                </EasingDoubleKeyFrame.EasingFunction>
                                                                            </EasingDoubleKeyFrame>
                                                                            <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="0" />
                                                                        </DoubleAnimationUsingKeyFrames>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </EventTrigger>
                                                        </StackPanel.Triggers>
                                                        <Ellipse x:Name="Dot1" Width="8" Height="8" Fill="#7890AA" Margin="5,0" Opacity="0.25">
                                                            <Ellipse.RenderTransform>
                                                                <TranslateTransform x:Name="Dot1Transform" />
                                                            </Ellipse.RenderTransform>
                                                        </Ellipse>
                                                        <Ellipse x:Name="Dot2" Width="8" Height="8" Fill="#7890AA" Margin="5,0" Opacity="0.25">
                                                            <Ellipse.RenderTransform>
                                                                <TranslateTransform x:Name="Dot2Transform" />
                                                            </Ellipse.RenderTransform>
                                                        </Ellipse>
                                                        <Ellipse x:Name="Dot3" Width="8" Height="8" Fill="#7890AA" Margin="5,0" Opacity="0.25">
                                                            <Ellipse.RenderTransform>
                                                                <TranslateTransform x:Name="Dot3Transform" />
                                                            </Ellipse.RenderTransform>
                                                        </Ellipse>
                                                    </StackPanel>
                                                    <TextBlock x:Name="QuickOpenLoadingText"
                                                               HorizontalAlignment="Center"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="#607286"
                                                               Text="正在索引工作区..." />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Popup>

                        <Popup x:Name="RecentFilesPopup"
                               PlacementTarget="{Binding ElementName=RecentFilesButton}"
                               Placement="Bottom"
                               VerticalOffset="8"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               StaysOpen="False"
                               Opened="OnRecentFilesPopupOpened">
                            <Border Width="360"
                                    Background="#FFFFFF"
                                    BorderBrush="#DCE4EE"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000"
                                                      Opacity="0.12"
                                                      BlurRadius="24"
                                                      ShadowDepth="6"
                                                      Direction="270" />
                                </Border.Effect>
                                <Grid MaxHeight="480">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Margin="6,4,6,8"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#434C5E"
                                               Text="Recent Files" />

                                    <TextBlock x:Name="RecentFilesEmptyText"
                                               Grid.Row="1"
                                               Margin="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Foreground="#8A96A7"
                                               Text="No recent files"
                                               Visibility="Collapsed" />

                                    <ListBox x:Name="RecentFilesList"
                                             Grid.Row="1"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ItemContainerStyle="{StaticResource QuickOpenResultItemStyle}"
                                             SelectionMode="Single"
                                             PreviewMouseLeftButtonUp="OnRecentFileItemClicked">
                                        <ListBox.Template>
                                            <ControlTemplate TargetType="ListBox">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled"
                                                              Focusable="False">
                                                    <ScrollViewer.Resources>
                                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource QuickOpenVerticalScrollBarStyle}" />
                                                    </ScrollViewer.Resources>
                                                    <ItemsPresenter />
                                                </ScrollViewer>
                                            </ControlTemplate>
                                        </ListBox.Template>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Popup>

                        <Popup x:Name="SkillsPopup"
                               PlacementTarget="{Binding ElementName=SkillsButton}"
                               Placement="Bottom"
                               VerticalOffset="8"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               StaysOpen="False"
                               Opened="OnSkillsPopupOpened">
                            <Border Width="380"
                                    Background="#FFFFFF"
                                    BorderBrush="#DCE4EE"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000"
                                                      Opacity="0.12"
                                                      BlurRadius="24"
                                                      ShadowDepth="6"
                                                      Direction="270" />
                                </Border.Effect>
                                <Grid MaxHeight="480">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <TextBlock x:Name="SkillsPopupTitleText"
                                               Margin="6,4,6,8"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#434C5E"
                                               Text="Skill Docs" />

                                    <TextBlock x:Name="SkillsEmptyText"
                                               Grid.Row="1"
                                               Margin="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Foreground="#8A96A7"
                                               Text="No skill documents found."
                                               Visibility="Collapsed" />

                                    <ListBox x:Name="SkillsList"
                                             Grid.Row="1"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             ItemContainerStyle="{StaticResource QuickOpenResultItemStyle}"
                                             SelectionMode="Single"
                                             PreviewMouseLeftButtonUp="OnSkillItemClicked">
                                        <ListBox.Template>
                                            <ControlTemplate TargetType="ListBox">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled"
                                                              Focusable="False">
                                                    <ScrollViewer.Resources>
                                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource QuickOpenVerticalScrollBarStyle}" />
                                                    </ScrollViewer.Resources>
                                                    <ItemsPresenter />
                                                </ScrollViewer>
                                            </ControlTemplate>
                                        </ListBox.Template>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Popup>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <Button x:Name="MinimizeButton"
                            Style="{StaticResource WindowMinimizeButton}"
                            Margin="0,0,2,0"
                            Click="OnMinimizeClicked"
                            ToolTip="Minimize"
                            AutomationProperties.AutomationId="WindowMinimizeButton"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                    <Button x:Name="CloseButton"
                            Style="{StaticResource WindowCloseButton}"
                            Click="OnCloseClicked"
                            ToolTip="Close"
                            AutomationProperties.AutomationId="WindowCloseButton"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border x:Name="SidebarContainer"
                    Width="0"
                    Background="#F3F4F6"
                    BorderBrush="#1A434C5E"
                    BorderThickness="0,0,1,0"
                    Opacity="0"
                    Visibility="Collapsed">
                <Grid Margin="10,10,8,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="WorkspaceFolderNameText"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#4A5568"
                                       TextTrimming="CharacterEllipsis"
                                       Text="WORKSPACE"
                                       Visibility="Visible" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Style="{StaticResource PanelIconButton}"
                                VerticalAlignment="Top"
                                Margin="0,0,0,0"
                                Click="OnToggleSidebarClicked"
                                ToolTip="Toggle Workspace (Ctrl+Shift+L)">
                            <!-- 面板布局图标（836f7a.svg，20×20 坐标系） -->
                            <Path Width="14" Height="14"
                                  Stretch="Uniform"
                                  Fill="#5E6E82"
                                  Data="M6.835 4c-.451.004-.82.012-1.137.038-.386.032-.659.085-.876.162l-.2.086c-.44.224-.807.564-1.063.982l-.103.184c-.126.247-.206.562-.248 1.076-.043.523-.043 1.19-.043 2.135v2.664c0 .944 0 1.612.043 2.135.042.515.122.829.248 1.076l.103.184c.256.418.624.758 1.063.982l.2.086c.217.077.49.13.876.162.316.026.685.034 1.136.038zm11.33 7.327c0 .922 0 1.654-.048 2.243-.043.522-.125.977-.305 1.395l-.082.177a4 4 0 0 1-1.473 1.593l-.276.155c-.465.237-.974.338-1.57.387-.59.048-1.322.048-2.244.048H7.833c-.922 0-1.654 0-2.243-.048-.522-.042-.977-.126-1.395-.305l-.176-.082a4 4 0 0 1-1.594-1.473l-.154-.275c-.238-.466-.34-.975-.388-1.572-.048-.589-.048-1.32-.048-2.243V8.663c0-.922 0-1.654.048-2.243.049-.597.15-1.106.388-1.571l.154-.276a4 4 0 0 1 1.594-1.472l.176-.083c.418-.18.873-.263 1.395-.305.589-.048 1.32-.048 2.243-.048h4.334c.922 0 1.654 0 2.243.048.597.049 1.106.15 1.571.388l.276.154a4 4 0 0 1 1.473 1.594l.082.176c.18.418.262.873.305 1.395.048.589.048 1.32.048 2.243zm-10 4.668h4.002c.944 0 1.612 0 2.135-.043.514-.042.829-.122 1.076-.248l.184-.103c.418-.256.758-.624.982-1.063l.086-.2c.077-.217.13-.49.162-.876.043-.523.043-1.19.043-2.135V8.663c0-.944 0-1.612-.043-2.135-.032-.386-.085-.659-.162-.876l-.086-.2a2.67 2.67 0 0 0-.982-1.063l-.184-.103c-.247-.126-.562-.206-1.076-.248-.523-.043-1.19-.043-2.135-.043H8.164L8.165 4z" />
                        </Button>
                    </Grid>

                    <TreeView x:Name="FileTreeView"
                              Grid.Row="1"
                              Margin="0,6,0,0"
                              Style="{StaticResource FileTreeViewStyle}"
                              ItemsSource="{Binding FileTreeNodes}"
                              AutomationProperties.AutomationId="WorkspaceFileTree"
                              AllowDrop="True"
                              Drop="OnFileTreeDrop"
                              DragOver="OnFileTreeDragOver"
                              SelectedItemChanged="OnFileTreeSelectionChanged" />
                </Grid>
            </Border>

            <!-- Sidebar resize handle -->
            <Border x:Name="SidebarResizeHandle"
                    Grid.Column="1"
                    Width="12"
                    Margin="-6,0,0,0"
                    HorizontalAlignment="Left"
                    Background="Transparent"
                    Cursor="SizeWE"
                    Panel.ZIndex="100"
                    Visibility="Collapsed"
                    MouseEnter="OnSidebarResizeMouseEnter"
                    MouseLeave="OnSidebarResizeMouseLeave"
                    MouseLeftButtonDown="OnSidebarResizeMouseDown"
                    MouseLeftButtonUp="OnSidebarResizeMouseUp"
                    MouseMove="OnSidebarResizeMouseMove">
                <Border x:Name="SidebarResizeGrip"
                        Width="4"
                        Height="32"
                        CornerRadius="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#9AA4B0"
                        Opacity="0" />
            </Border>

            <!-- Outline resize handle -->
            <Border x:Name="OutlineResizeHandle"
                    Grid.Column="1"
                    Width="12"
                    Margin="0,0,-6,0"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    Cursor="SizeWE"
                    Panel.ZIndex="100"
                    Visibility="Collapsed"
                    MouseEnter="OnOutlineResizeMouseEnter"
                    MouseLeave="OnOutlineResizeMouseLeave"
                    MouseLeftButtonDown="OnOutlineResizeMouseDown"
                    MouseLeftButtonUp="OnOutlineResizeMouseUp"
                    MouseMove="OnOutlineResizeMouseMove">
                <Border x:Name="OutlineResizeGrip"
                        Width="4"
                        Height="32"
                        CornerRadius="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#9AA4B0"
                        Opacity="0" />
            </Border>

            <Grid Grid.Column="1">
                <Grid x:Name="WebViewHost">
                    <wv2:WebView2 x:Name="MainWebView" />
                </Grid>

                <Border x:Name="LoadingOverlay"
                        Margin="30,26,30,30"
                        Padding="18"
                        Background="#F2F9FAFB"
                        BorderBrush="#33434C5E"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="LoadingText"
                                   HorizontalAlignment="Center"
                                   FontSize="13"
                                   Foreground="#8C434C5E"
                                   Text="Loading document..." />
                        <ProgressBar Margin="0,12,0,0"
                                     Height="5"
                                     IsIndeterminate="True"
                                     Foreground="#81A1C1" />
                    </StackPanel>
                </Border>

                <Border x:Name="ErrorToast"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,16,22,0"
                        Padding="10,8"
                        Background="#33BF616A"
                        BorderBrush="#66BF616A"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="Collapsed"
                        Opacity="0">
                    <DockPanel>
                        <TextBlock x:Name="ErrorText"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   Foreground="#8F2D37"
                                   FontSize="12"
                                   Text="Save failed." />
                        <Button x:Name="RetrySaveButton"
                                Width="54"
                                Height="22"
                                BorderThickness="0"
                                Background="#99FFFFFF"
                                Foreground="#8F2D37"
                                AutomationProperties.AutomationId="RetrySaveButton"
                                Click="OnRetrySaveClicked"
                                Content="Retry" />
                    </DockPanel>
                </Border>

                <Border x:Name="SyncConflictToast"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,62,22,0"
                        Padding="10,8"
                        Background="#335E81AC"
                        BorderBrush="#665E81AC"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="Collapsed"
                        Opacity="0">
                    <DockPanel>
                        <TextBlock x:Name="SyncConflictText"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   Foreground="#3A4A63"
                                   FontSize="12"
                                   Text="External file changed. Keep local or reload external?" />
                        <Button x:Name="KeepLocalButton"
                                Width="72"
                                Height="22"
                                Margin="0,0,6,0"
                                BorderThickness="0"
                                Background="#99FFFFFF"
                                Foreground="#3A4A63"
                                AutomationProperties.AutomationId="KeepLocalButton"
                                Click="OnKeepLocalClicked"
                                Content="Keep Local" />
                        <Button x:Name="AcceptExternalButton"
                                Width="92"
                                Height="22"
                                BorderThickness="0"
                                Background="#99FFFFFF"
                                Foreground="#3A4A63"
                                AutomationProperties.AutomationId="AcceptExternalButton"
                                Click="OnAcceptExternalClicked"
                                Content="Use External" />
                    </DockPanel>
                </Border>

                <Border x:Name="SavingDot"
                        Width="9"
                        Height="9"
                        CornerRadius="4.5"
                        Background="#81A1C1"
                        Opacity="0.4"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,20,20"
                        Visibility="Collapsed" />
            </Grid>

            <Border x:Name="OutlineContainer"
                    Grid.Column="2"
                    Width="0"
                    Background="#F3F4F6"
                    BorderBrush="#1A434C5E"
                    BorderThickness="1,0,0,0"
                    Opacity="0"
                    Visibility="Collapsed">
                <Grid Margin="8,10,10,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Margin="0,0,6,0"
                                Style="{StaticResource PanelIconButton}"
                                Click="OnToggleOutlineClicked"
                                ToolTip="Toggle Outline (Ctrl+Shift+O)">
                            <!-- 同 836f7a.svg，水平镜像得到右侧面板图标 -->
                            <Path Width="14" Height="14"
