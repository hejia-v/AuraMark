<Window x:Class="AuraMark.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:AuraMark.App.Models"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="AuraMark"
        Width="1280"
        Height="800"
        MinWidth="980"
        MinHeight="640"
        Background="#F9FAFB"
        WindowStyle="None"
        ResizeMode="CanResize"
        PreviewKeyDown="OnWindowPreviewKeyDown"
        MouseMove="OnWindowMouseMove">
    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="12"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <HierarchicalDataTemplate DataType="{x:Type models:FileTreeNode}" ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding Name}" />
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="Transparent" shell:WindowChrome.IsHitTestVisibleInChrome="True" />

        <Border x:Name="TopBar"
                Grid.Row="0"
                Background="#F3F4F6"
                BorderBrush="#1A434C5E"
                BorderThickness="0,0,0,1"
                Opacity="1">
            <Grid Margin="14,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="FileNameText"
                               Margin="0,0,12,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#434C5E"
                               Text="Untitled.md" />
                    <TextBlock x:Name="StateText"
                               FontSize="12"
                               Foreground="#8C434C5E"
                               Text="Idle" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ToggleSidebarButton"
                            Width="46"
                            Height="24"
                            Margin="0,0,4,0"
                            BorderThickness="0"
                            Background="#00000000"
                            Click="OnToggleSidebarClicked"
                            ToolTip="Toggle Sidebar (Ctrl+Shift+L)"
                            Content="Menu" />
                    <Button Width="52"
                            Height="24"
                            Margin="0,0,4,0"
                            BorderThickness="0"
                            Background="#00000000"
                            Click="OnNewFileClicked"
                            ToolTip="New (Ctrl+N)"
                            Content="New" />
                    <Button Width="52"
                            Height="24"
                            Margin="0,0,4,0"
                            BorderThickness="0"
                            Background="#00000000"
                            Click="OnOpenFileClicked"
                            ToolTip="Open (Ctrl+O)"
                            Content="Open" />
                    <Button Width="52"
                            Height="24"
                            Margin="0,0,4,0"
                            BorderThickness="0"
                            Background="#00000000"
                            Click="OnSaveNowClicked"
                            ToolTip="Save (Ctrl+S)"
                            Content="Save" />
                    <Button Width="62"
                            Height="24"
                            BorderThickness="0"
                            Background="#00000000"
                            Click="OnExportHtmlClicked"
                            ToolTip="Export HTML"
                            Content="Export" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="SidebarContainer"
                    Width="0"
                    Background="#F3F4F6"
                    BorderBrush="#1A434C5E"
                    BorderThickness="0,0,1,0"
                    Opacity="0"
                    Visibility="Collapsed">
                <Grid Margin="10,10,8,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#8C434C5E"
                               Text="FILES" />

                    <TreeView x:Name="FileTreeView"
                              Grid.Row="1"
                              Margin="0,6,0,10"
                              BorderThickness="0"
                              Background="#00000000"
                              Foreground="#434C5E"
                              ItemsSource="{Binding FileTreeNodes}"
                              SelectedItemChanged="OnFileTreeSelectionChanged" />

                    <TextBlock Grid.Row="2"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#8C434C5E"
                               Text="OUTLINE" />

                    <ListBox x:Name="OutlineList"
                             Grid.Row="3"
                             Margin="0,6,0,0"
                             BorderThickness="0"
                             Background="#00000000"
                             Foreground="#434C5E"
                             DisplayMemberPath="DisplayText"
                             ItemsSource="{Binding OutlineItems}"
                             SelectionChanged="OnOutlineSelectionChanged" />
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <wv2:WebView2 x:Name="MainWebView" Margin="14,10,14,14" />

                <Border x:Name="LoadingOverlay"
                        Margin="30,26,30,30"
                        Padding="18"
                        Background="#F2F9FAFB"
                        BorderBrush="#33434C5E"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="LoadingText"
                                   HorizontalAlignment="Center"
                                   FontSize="13"
                                   Foreground="#8C434C5E"
                                   Text="Loading document..." />
                        <ProgressBar Margin="0,12,0,0"
                                     Height="5"
                                     IsIndeterminate="True"
                                     Foreground="#81A1C1" />
                    </StackPanel>
                </Border>

                <Border x:Name="ErrorToast"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,16,22,0"
                        Padding="10,8"
                        Background="#33BF616A"
                        BorderBrush="#66BF616A"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="Collapsed"
                        Opacity="0">
                    <DockPanel>
                        <TextBlock x:Name="ErrorText"
                                   Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   Foreground="#8F2D37"
                                   FontSize="12"
                                   Text="Save failed." />
                        <Button x:Name="RetrySaveButton"
                                Width="54"
                                Height="22"
                                BorderThickness="0"
                                Background="#99FFFFFF"
                                Foreground="#8F2D37"
                                Click="OnRetrySaveClicked"
                                Content="Retry" />
                    </DockPanel>
                </Border>

                <Border x:Name="SavingDot"
                        Width="9"
                        Height="9"
                        CornerRadius="4.5"
                        Background="#81A1C1"
                        Opacity="0.4"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,20,20"
                        Visibility="Collapsed" />
            </Grid>
        </Grid>
    </Grid>
</Window>
